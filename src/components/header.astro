---
import Container from "@/components/container.astro";
import Link from "@/components/link.astro";
import { SITE } from "@/config/site";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

const navLinks = [
  { href: "/", label: "home" },
  { href: "/work", label: "work" },
  { href: "/projects", label: "projects" },
  { href: "/blog", label: "blog" },
  { href: "/about", label: "about" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 py-5 bg-background/75 dark:bg-background/25 backdrop-blur-sm saturate-200"
>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between items-center">
      <Link href="/" underline={false}>
        <div class="header-name">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1 items-center">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { "nav-link--active": isActive(link.href) }]}
            {...(isActive(link.href) ? { "aria-current": "page" } : {})}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </Container>
</header>

<style>
.header-name {
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-base);
  letter-spacing: var(--letter-spacing-tight);
}

.nav-link {
  color: var(--color-muted-foreground);
  text-decoration: none;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.nav-link:hover {
  color: var(--color-foreground);
  background-color: var(--color-muted);
}

.nav-link--active {
  color: var(--color-foreground);
  background-color: var(--color-muted);
}
</style>

---
import "@/styles/globals.css";

import { getCollection } from "astro:content";
import Container from "@/components/container.astro";
import PageLayout from "@/layouts/page-layout.astro";
import SimpleLink from "@/components/simple-link.astro";
import Link from "@/components/link.astro";
import { SITE, HOME, SOCIALS } from "@/config/site";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h1 class="page-title" style="margin-bottom: var(--spacing-xl);">
      {HOME.TITLE}
    </h1>
    <div class="space-y-24">
      <section>
        <article class="space-y-4">
          <p>
            I'm a software engineer who gets genuinely excited about data. There's something satisfying
            about taking messy, chaotic information and turning it into something that actually helps
            people make decisions.
          </p>
          <p>
            Right now I'm at <strong>Consumer Genius</strong>, building data pipelines and figuring out
            how to make sense of data from multiple sources without wanting to pull your hair out. Before that,
            I helped build <strong>Fire AI</strong> at Hummingbird Drones - an ML system that spots
            wildfires from drone footage. Turns out teaching computers to see fire is harder than it sounds.
          </p>
        </article>
      </section>

      <section class="space-y-6">
        <div class="section-header-container">
          <h2 class="section-header">
            Latest posts
          </h2>
          <Link href="/blog" class="section-link"> See all posts </Link>
        </div>
        <ul class="flex flex-col list-none space-y-4">
          {
            blog.map((post) => (
              <li>
                <SimpleLink entry={post} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="space-y-6">
        <div class="section-header-container">
          <h2 class="section-header">
            Recent projects
          </h2>
          <Link href="/projects" class="section-link"> See all projects </Link>
        </div>
        <ul class="flex flex-col list-none space-y-4">
          {
            projects.map((project) => (
              <li>
                <SimpleLink entry={project} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="section-header">
          Say hello
        </h2>
        <article>
          <p>
            Want to chat about data, side projects, or just say hi? I'm always happy to connect.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2 list-none">
          {
            SOCIALS.map((SOCIAL) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={SOCIAL.HREF}
                  external
                  aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
          <li class="line-clamp-1">
            <Link
              href={`mailto:${SITE.EMAIL}`}
              aria-label={`Email ${SITE.NAME}`}
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>

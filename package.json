{
  "name": "astro-portfolio",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:worker": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "astro": "astro",
    "lint": "biome lint .",
    "format": "biome format . ",
    "security:audit": "pnpm audit --audit-level moderate",
    "security:outdated": "pnpm outdated",
    "security:update": "pnpm update --latest",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-toc": "^9.0.0",
    "sharp": "^0.35.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "undici": ">=7.24.0",
      "fast-xml-parser": ">=5.5.7"
    }
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.4",
    "astro": "^7.0.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.111.0"
  }
}
